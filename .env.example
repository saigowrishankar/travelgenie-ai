# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Option A: full connection URL (takes precedence if set)
DATABASE_URL=postgresql://travelgenie:password@localhost:5432/travelgenie

# Option B: individual fields (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=travelgenie
DB_USER=travelgenie
DB_PASS=password

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=8000
FREE_SEARCHES_PER_IP=5
CACHE_TTL_DAYS=7
RATE_WINDOW_HOURS=24
